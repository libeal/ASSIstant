#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Keep startup validation identical to the CLI.  In particular, audit
# durability settings must not be normalized differently by the Web adapter.
# shellcheck source=../lib/common.sh
source "${ROOT_DIR}/lib/common.sh"
# shellcheck source=../lib/config.sh
source "${ROOT_DIR}/lib/config.sh"

require_command() {
    local name="$1"
    if ! command -v "${name}" >/dev/null 2>&1; then
        printf '[错误] 缺少依赖命令: %s\n' "${name}" >&2
        exit 1
    fi
}

config_get() {
    local query="$1"
    local default_value="$2"
    linux_agent_config_get_default "${query}" "${default_value}"
}

generate_token() {
    python3 -c 'import secrets; print(secrets.token_hex(32))'
}

require_command jq
require_command python3
linux_agent_require_python_runtime
linux_agent_init_env "${ROOT_DIR}"
linux_agent_load_config

enabled="$(config_get '.web.enabled' 'true')"
case "${enabled,,}" in
    true | 1 | yes | on) ;;
    *)
        printf '[错误] config/config.json 中 web.enabled 已关闭。\n' >&2
        exit 1
        ;;
esac

host="$(config_get '.web.host' '127.0.0.1')"
port="$(config_get '.web.port' '8765')"
token="$(config_get '.web.token' '')"
retention="$(config_get '.web.job_retention_hours' '24')"
max_active_jobs="$(config_get '.web.max_active_jobs' '4')"
job_timeout="$(config_get '.web.job_timeout_sec' '900')"
max_job_attempts="$(config_get '.web.max_job_attempts' '3')"
cancel_grace="$(config_get '.web.cancel_grace_sec' '2')"

[[ -n "${host}" ]] || host="127.0.0.1"
if [[ "${LINUX_AGENT_REMOTE_MODE:-0}" == "1" ]]; then
    host="127.0.0.1"
    if [[ -n "${LINUX_AGENT_REMOTE_WEB_PORT:-}" ]]; then
        port="${LINUX_AGENT_REMOTE_WEB_PORT}"
    fi
fi
if [[ ! "${port}" =~ ^[0-9]+$ || "${port}" -le 0 || "${port}" -gt 65535 ]]; then
    printf '[错误] web.port 必须是 1-65535 的整数。\n' >&2
    exit 1
fi
if [[ ! "${retention}" =~ ^[0-9]+$ || "${retention}" -le 0 ]]; then
    retention=24
fi
if [[ ! "${max_active_jobs}" =~ ^[0-9]+$ || "${max_active_jobs}" -le 0 || "${max_active_jobs}" -gt 64 ]]; then
    printf '[错误] web.max_active_jobs 必须是 1-64 的整数。\n' >&2
    exit 1
fi
if [[ ! "${job_timeout}" =~ ^[0-9]+$ || "${job_timeout}" -le 0 || "${job_timeout}" -gt 86400 ]]; then
    printf '[错误] web.job_timeout_sec 必须是 1-86400 的整数。\n' >&2
    exit 1
fi
if [[ ! "${max_job_attempts}" =~ ^[0-9]+$ || "${max_job_attempts}" -le 0 || "${max_job_attempts}" -gt 10 ]]; then
    printf '[错误] web.max_job_attempts 必须是 1-10 的整数。\n' >&2
    exit 1
fi
if [[ ! "${cancel_grace}" =~ ^[0-9]+$ || "${cancel_grace}" -gt 30 ]]; then
    printf '[错误] web.cancel_grace_sec 必须是 0-30 的整数。\n' >&2
    exit 1
fi
if [[ -z "${token}" ]]; then
    token="$(generate_token)"
    export LINUX_AGENT_WEB_TOKEN_EPHEMERAL=1
    printf '[警告] web.token 未配置，已生成本次运行临时 token（写入 tmp/web/auth-token，不在终端回显）。\n' >&2
fi

export LINUX_AGENT_ROOT="${ROOT_DIR}"
export LINUX_AGENT_WEB_HOST="${host}"
export LINUX_AGENT_WEB_PORT="${port}"
export LINUX_AGENT_WEB_TOKEN="${token}"
export LINUX_AGENT_WEB_JOB_RETENTION_HOURS="${retention}"
export LINUX_AGENT_WEB_MAX_ACTIVE_JOBS="${max_active_jobs}"
export LINUX_AGENT_WEB_JOB_TIMEOUT_SEC="${job_timeout}"
export LINUX_AGENT_WEB_MAX_JOB_ATTEMPTS="${max_job_attempts}"
export LINUX_AGENT_WEB_CANCEL_GRACE_SEC="${cancel_grace}"

if [[ "${LINUX_AGENT_REMOTE_MODE:-0}" == "1" ]]; then
    printf '[信息] SSH 转发示例: ssh -L %s:127.0.0.1:%s <user>@<remote-host>\n' "${port}" "${port}" >&2
fi

exec python3 "${ROOT_DIR}/web/server.py"
