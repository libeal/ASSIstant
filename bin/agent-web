#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
CONFIG_FILE="${ROOT_DIR}/config/config.json"
EXAMPLE_FILE="${ROOT_DIR}/config/config.example.json"

require_command() {
    local name="$1"
    if ! command -v "${name}" >/dev/null 2>&1; then
        printf '[错误] 缺少依赖命令: %s\n' "${name}" >&2
        exit 1
    fi
}

config_get() {
    local query="$1"
    local default_value="$2"
    jq -r --arg default_value "${default_value}" "${query} // \$default_value" "${CONFIG_FILE}"
}

generate_token() {
    {
        date +%s%N
        printf '%s\n' "$$"
        printf '%s\n' "${RANDOM}${RANDOM}${RANDOM}"
        uname -a 2>/dev/null || true
    } | sha256sum | awk '{print $1}' | cut -c 1-32
}

require_command jq
require_command python3

if [[ ! -f "${CONFIG_FILE}" ]]; then
    mkdir -p "$(dirname "${CONFIG_FILE}")"
    cp "${EXAMPLE_FILE}" "${CONFIG_FILE}"
    printf '[警告] 未找到 config/config.json，已根据示例生成；请补充真实 AI 配置。\n' >&2
fi

if ! jq -e . "${CONFIG_FILE}" >/dev/null 2>&1; then
    printf '[错误] config/config.json 不是合法 JSON。\n' >&2
    exit 1
fi

enabled="$(config_get '.web.enabled' 'true')"
case "${enabled,,}" in
    true|1|yes|on)
        ;;
    *)
        printf '[错误] config/config.json 中 web.enabled 已关闭。\n' >&2
        exit 1
        ;;
esac

host="$(config_get '.web.host' '127.0.0.1')"
port="$(config_get '.web.port' '8765')"
token="$(config_get '.web.token' '')"
retention="$(config_get '.web.job_retention_hours' '24')"

[[ -n "${host}" ]] || host="127.0.0.1"
if [[ ! "${port}" =~ ^[0-9]+$ || "${port}" -le 0 || "${port}" -gt 65535 ]]; then
    printf '[错误] web.port 必须是 1-65535 的整数。\n' >&2
    exit 1
fi
if [[ ! "${retention}" =~ ^[0-9]+$ || "${retention}" -le 0 ]]; then
    retention=24
fi
if [[ -z "${token}" ]]; then
    token="$(generate_token)"
    printf '[警告] web.token 未配置，已生成本次运行临时 token。\n' >&2
fi

export LINUX_AGENT_ROOT="${ROOT_DIR}"
export LINUX_AGENT_WEB_HOST="${host}"
export LINUX_AGENT_WEB_PORT="${port}"
export LINUX_AGENT_WEB_TOKEN="${token}"
export LINUX_AGENT_WEB_JOB_RETENTION_HOURS="${retention}"

exec python3 "${ROOT_DIR}/web/server.py"
