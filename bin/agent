#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# shellcheck source=../lib/common.sh
source "${ROOT_DIR}/lib/common.sh"
# shellcheck source=../lib/config.sh
source "${ROOT_DIR}/lib/config.sh"
# shellcheck source=../lib/audit.sh
source "${ROOT_DIR}/lib/audit.sh"
# shellcheck source=../lib/context.sh
source "${ROOT_DIR}/lib/context.sh"
# shellcheck source=../lib/sense.sh
source "${ROOT_DIR}/lib/sense.sh"
# shellcheck source=../lib/skills.sh
source "${ROOT_DIR}/lib/skills.sh"
# shellcheck source=../lib/doctor.sh
source "${ROOT_DIR}/lib/doctor.sh"
# shellcheck source=../lib/ai.sh
source "${ROOT_DIR}/lib/ai.sh"
# shellcheck source=../lib/policy.sh
source "${ROOT_DIR}/lib/policy.sh"
# shellcheck source=../lib/observer.sh
source "${ROOT_DIR}/lib/observer.sh"
# shellcheck source=../lib/executor.sh
source "${ROOT_DIR}/lib/executor.sh"
# shellcheck source=../lib/editor.sh
source "${ROOT_DIR}/lib/editor.sh"
# shellcheck source=../lib/api.sh
source "${ROOT_DIR}/lib/api.sh"
# shellcheck source=../lib/interactive.sh
source "${ROOT_DIR}/lib/interactive.sh"
# shellcheck source=../lib/orchestrator.sh
source "${ROOT_DIR}/lib/orchestrator.sh"

linux_agent_init_env "${ROOT_DIR}"
linux_agent_load_config

LINUX_AGENT_MAIN_COMMAND=""
LINUX_AGENT_COMMAND_FINISHED=0
LINUX_AGENT_FINAL_STATUS=""

linux_agent_finish_run() {
    local final_status="$1"
    local exit_code="${2:-0}"
    [[ -n "${LINUX_AGENT_MAIN_COMMAND:-}" ]] || return 0

    if [[ "${LINUX_AGENT_COMMAND_FINISHED:-0}" -eq 0 ]]; then
        linux_agent_log_command_finished "${LINUX_AGENT_MAIN_COMMAND}" "${final_status}" "${exit_code}"
        LINUX_AGENT_COMMAND_FINISHED=1
    fi
    linux_agent_finish_session "${final_status}"
    linux_agent_cleanup_tmp_dir
}

linux_agent_status_for_exit_code() {
    local exit_code="$1"
    if [[ -n "${LINUX_AGENT_FINAL_STATUS:-}" ]]; then
        printf '%s\n' "${LINUX_AGENT_FINAL_STATUS}"
    elif [[ "${exit_code}" -eq 0 ]]; then
        printf '%s\n' "${LINUX_AGENT_LAST_BUSINESS_STATUS:-completed}"
    else
        printf 'failed\n'
    fi
}

linux_agent_on_exit() {
    local exit_code=$?
    local final_status
    set +e
    final_status="$(linux_agent_status_for_exit_code "${exit_code}")"
    linux_agent_finish_run "${final_status}" "${exit_code}"
}

linux_agent_on_int() {
    set +e
    LINUX_AGENT_FINAL_STATUS="interrupted"
    linux_agent_log_control_event "signal_int" "" "INT" "interrupted"
    exit 130
}

linux_agent_on_term() {
    set +e
    LINUX_AGENT_FINAL_STATUS="terminated"
    linux_agent_log_control_event "signal_term" "" "TERM" "terminated"
    exit 143
}

linux_agent_on_tstp() {
    set +e
    LINUX_AGENT_FINAL_STATUS="exited_ctrl_z"
    linux_agent_log_control_event "ctrl_z" "" "SIGTSTP" "exited"
    exit 0
}

linux_agent_usage() {
    cat <<'EOF'
用法:
  agent                         进入四模式 REPL，默认工作模式
  agent work "<自然语言指令>"     工作模式单次请求
  agent edit "<自然语言指令>"     编辑或新建 skill
  agent script <skill>/<script> [json-args]
                                执行已登记 skill 脚本
  agent terminal "<shell命令>"   终端模式单次执行并记录审计
  agent doctor                    检查依赖、配置和 skill 目录
  agent sense <topic>           采集环境信息
  agent tools list              列出可用 skill 脚本索引
  agent skills validate         校验 skill 目录
  agent api <resource> <action> [json]
                                机器可读 JSON API，供 Web 前端调用
  agent audit <session-id>      查看审计摘要

REPL 命令:
  /work                         切换到工作模式
  /edit                         切换到编辑模式
  /script                       切换到脚本模式
  /terminal                     切换到终端模式
  /mode                         打开模式选择菜单
  /help                         显示帮助
  /exit                         退出

提示:
  输入 / 或 /前缀 后回车会打开命令菜单，可用上下键选择。
  编辑模式保存脚本前会打开 $EDITOR 或 vi 供你确认/修改。
  终端模式会先做策略审查；低风险命令直接执行，需权限或高风险命令会请求审批，并写入审计日志。
EOF
}

linux_agent_interactive() {
    local current_mode="work"
    local user_input original_input selected_mode turn_status
    linux_agent_print_info "Linux 运维 Agent 已就绪，默认工作模式。输入 / 或 /help 查看命令，/exit 结束。"
    while true; do
        if ! linux_agent_read_repl_input "${current_mode}" user_input; then
            linux_agent_log_control_event "eof" "${current_mode}" "" "eof"
            LINUX_AGENT_FINAL_STATUS="eof"
            break
        fi
        if [[ "${user_input}" == *$'\032'* ]]; then
            linux_agent_log_control_event "ctrl_z" "${current_mode}" "SUB" "exited"
            LINUX_AGENT_FINAL_STATUS="exited_ctrl_z"
            break
        fi

        original_input="${user_input}"
        if [[ "${user_input}" == /* ]]; then
            if ! user_input="$(linux_agent_slash_command_complete "${user_input}")"; then
                linux_agent_log_control_event "slash_rejected" "${current_mode}" "${original_input}" "rejected"
                continue
            fi
        fi

        case "${user_input}" in
            /exit|exit)
                linux_agent_log_control_event "exit" "${current_mode}" "${user_input}" "exited"
                LINUX_AGENT_FINAL_STATUS="exited"
                break
                ;;
            /work)
                current_mode="work"
                linux_agent_log_control_event "mode_changed" "${current_mode}" "${user_input}" "work"
                linux_agent_print_info "已切换到工作模式。"
                continue
                ;;
            /edit)
                current_mode="edit"
                linux_agent_log_control_event "mode_changed" "${current_mode}" "${user_input}" "edit"
                linux_agent_print_info "已切换到编辑模式。"
                continue
                ;;
            /script)
                current_mode="script"
                linux_agent_log_control_event "mode_changed" "${current_mode}" "${user_input}" "script"
                linux_agent_print_info "已切换到脚本模式。输入形如 ops-basic/process-inspect '{\"pattern\":\"systemd\"}'。"
                continue
                ;;
            /terminal)
                current_mode="terminal"
                linux_agent_log_control_event "mode_changed" "${current_mode}" "${user_input}" "terminal"
                linux_agent_print_info "已切换到终端模式。普通输入会直接交给 bash -lc 执行；/mode 或 /work 可返回。"
                continue
                ;;
            /mode)
                selected_mode="$(linux_agent_mode_menu "${current_mode}")" || continue
                current_mode="${selected_mode}"
                linux_agent_log_control_event "mode_changed" "${current_mode}" "${user_input}" "${selected_mode}"
                linux_agent_print_info "已切换到${current_mode}模式。"
                continue
                ;;
            /help)
                linux_agent_log_control_event "help" "${current_mode}" "${user_input}" "shown"
                linux_agent_usage
                continue
                ;;
        esac
        if [[ "${user_input}" == "/exit" ]]; then
            break
        fi
        [[ -z "${user_input}" ]] && continue
        linux_agent_log_turn_started "${current_mode}" "${user_input}"
        set +e
        if [[ "${current_mode}" == "terminal" ]]; then
            linux_agent_process_terminal_request "${user_input}"
        else
            linux_agent_process_request "${user_input}" "${current_mode}"
        fi
        turn_status=$?
        set -e
        if [[ "${turn_status}" -eq 0 ]]; then
            linux_agent_log_turn_finished "${current_mode}" "${LINUX_AGENT_LAST_BUSINESS_STATUS:-completed}"
        else
            linux_agent_log_turn_finished "${current_mode}" "failed"
            return "${turn_status}"
        fi
    done
}

main() {
    local command="${1:-interactive}"
    case "${command}" in
        interactive)
            linux_agent_interactive
            ;;
        work)
            shift || true
            if [[ $# -eq 0 ]]; then
                linux_agent_print_error "缺少自然语言指令。"
                exit 1
            fi
            linux_agent_process_request "$*" "work"
            ;;
        edit)
            shift || true
            if [[ $# -eq 0 ]]; then
                linux_agent_print_error "缺少编辑需求。"
                exit 1
            fi
            linux_agent_process_request "$*" "edit"
            ;;
        script)
            shift || true
            if [[ $# -eq 0 ]]; then
                linux_agent_print_error "请提供 skill/script。"
                exit 1
            fi
            ref="$1"
            shift || true
            args="${1:-}"
            [[ -z "${args}" ]] && args='{}'
            linux_agent_process_script_request "${ref}" "${args}"
            ;;
        terminal)
            shift || true
            if [[ $# -eq 0 ]]; then
                linux_agent_print_error "缺少 shell 命令。"
                exit 1
            fi
            linux_agent_process_terminal_request "$*"
            ;;
        doctor)
            linux_agent_doctor
            ;;
        sense)
            shift || true
            linux_agent_sense_topic "${1:-all}"
            ;;
        tools)
            shift || true
            case "${1:-}" in
                list)
                    linux_agent_skill_index_text
                    ;;
                *)
                    linux_agent_print_error "仅支持 'agent tools list'。"
                    exit 1
                    ;;
            esac
            ;;
        skills)
            shift || true
            case "${1:-}" in
                validate)
                    linux_agent_validate_skills
                    ;;
                *)
                    linux_agent_print_error "仅支持 'agent skills validate'。"
                    exit 1
                    ;;
            esac
            ;;
        api)
            shift || true
            linux_agent_api_dispatch "${1:-health}" "${2:-}" "${3:-}"
            ;;
        audit)
            shift || true
            if [[ $# -eq 0 ]]; then
                linux_agent_print_error "请提供 session-id。"
                exit 1
            fi
            linux_agent_show_audit "$1"
            ;;
        -h|--help|help)
            linux_agent_usage
            ;;
        *)
            linux_agent_print_error "未知命令: ${command}"
            linux_agent_usage
            exit 1
            ;;
    esac
}

linux_agent_run() {
    local command="${1:-interactive}"
    local args_summary="$*"

    if [[ "${command}" == "audit" ]]; then
        main "$@"
        return $?
    fi
    if [[ "${command}" == "api" && "$(linux_agent_api_needs_session "${2:-health}" "${3:-}")" != "true" ]]; then
        main "$@"
        return $?
    fi

    LINUX_AGENT_MAIN_COMMAND="${command}"
    linux_agent_start_session "agent ${args_summary:-interactive}"
    linux_agent_log_command_started "${command}" "${args_summary}"

    trap linux_agent_on_exit EXIT
    trap linux_agent_on_int INT
    trap linux_agent_on_term TERM
    trap linux_agent_on_tstp TSTP

    main "$@"
    local exit_code=$?
    LINUX_AGENT_FINAL_STATUS="$(linux_agent_status_for_exit_code "${exit_code}")"
    linux_agent_finish_run "${LINUX_AGENT_FINAL_STATUS}" "${exit_code}"
    trap - EXIT INT TERM TSTP
    return "${exit_code}"
}

linux_agent_run "$@"
