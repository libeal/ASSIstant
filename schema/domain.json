    "high": [
      "failed",
      "blocked",
      "rejected",
      "terminated",
      "timed_out",
      "cancelled",
      "revision_failed",
      "critical",
      "high"
    ]
  },
  "contracts": {
    "error": {
      "required": [
        "ok",
        "code",
        "message",
        "retryable",
        "request_id",
        "details"
      ],
      "compatibility_aliases": {
        "status": "code",
        "error": "message"
      }
    },
    "job": {
      "required": [
        "schema_version",
        "job_id",
        "request_id",
        "session_id",
        "resource",
        "action",
        "status",
        "version",
        "attempt",
        "max_attempts",
        "created_at",
        "updated_at",
        "payload"
      ],
      "status_enum": "job_status"
    },
    "plan": {
      "required": [
        "response_type",
        "summary",
        "continue_decision",
        "steps"
      ],
      "response_type": "work_plan"
    },
    "approval": {
      "required": [
        "id",
        "type",
        "subject",
        "risk_level",
        "actions"
      ]
    },
    "execution_result": {
      "required": [
        "ok",
        "status",
        "timeline",
        "approval_card",
        "output_blocks"
      ],
      "status_enum": "result_status",
      "timeline_semantics": "step_projection"
    },
    "persisted_turn": {
      "required": [
        "id",
        "number",
        "status",
        "context_eligible",
        "result"
      ],
      "status_enum": "result_status"
    },
    "audit_event": {
      "required": [
        "schema_version",
        "timestamp",
        "session_id",
        "stage",
        "payload",
        "seq",
        "prev_hash",
        "hash",
        "request_id",
        "job_id",
        "system_user",
        "execution_user"
      ]
    },
    "skill_manifest": {
      "required": [
        "name",
        "description",
        "scripts"
      ]
    }
  },
