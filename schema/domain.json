  "status_presentation": {
    "low": [
      "ok",
      "executed",
      "succeeded",
      "success",
      "approved",
      "auto_approved",
      "answered"
    ],
    "medium": [
      "running",
      "queued",
      "approval_required",
      "pending",
      "policy_checked",
      "skipped_user",
      "skipped_unexecuted",
      "revision_requested",
