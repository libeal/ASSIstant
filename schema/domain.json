    "terminated",
    "revision_requested"
  ],
  "risk_level": [
    "low",
    "medium",
    "high",
    "critical"
  ],
  "executor_type": [
    "skill_script",
    "shell",
    "remote_script",
    "mcp_tool"
  ],
  "approval_type": [
    "work",
    "terminal"
  ],
  "approval_action": [
    "approve",
    "reject",
    "skip",
    "terminate"
  ],
  "work_status": [
