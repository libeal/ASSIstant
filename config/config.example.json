{
  "provider": "openai_compatible",
  "api_url": "https://api.openai.com/v1/chat/completions",
  "api_key": "",
  "model": "gpt-4.1-mini",
  "request_timeout_sec": 90,
  "context_turns": 6,
  "command_guard": {
    "enabled": true
  },
  "agent_loop": {
    "enabled_for_work": true,
    "observation_text_limit": 4000,
    "thinking_trace_enabled": false,
    "max_iterations": 12,
    "checkpoint_turns": 0
  },
  "approvals": {
    "auto": {
      "skill_readonly": true,
      "shell_readonly": false,
      "file_match": true,
      "file_patch": false,
      "file_download": false,
      "local_analyze": true,
      "remote_script": false
    }
  },
  "audit_mode": "safe_summary",
  "audit_text_limit": 1000,
  "audit": {
    "fsync": true,
    "max_bytes": 52428800,
    "min_free_bytes": 10485760,
    "on_full": "degrade"
  },
  "observer": {
    "enabled": "auto",
    "privilege": "sudo_interactive",
    "max_events": 200,
    "require": false
  },
  "execution": {
    "timeout_sec": 300,
    "min_privilege_proxy": true,
    "least_privilege_user": "nobody"
  },
  "skills_dir": "",
  "remote_script_policy": "download_review",
  "providers_security": {
    "require_https": false,
    "block_internal_addresses": true,
    "allowed_hosts": []
  },
  "remote": {
    "enabled": false,
    "release_version": "",
    "storage_backend": "local",
    "allow_api_key_transmission": false
  },
  "web": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 8765,
    "token": "",
    "job_retention_hours": 24,
    "max_active_jobs": 4,
    "job_timeout_sec": 900,
    "max_job_attempts": 3,
    "cancel_grace_sec": 2
  }
}
