# Optional systemd drop-in for linux-agent-web.service
# Install:
#   sudo mkdir -p /etc/systemd/system/linux-agent-web.service.d
#   sudo cp packaging/dropins/10-provider-egress.conf.example \
#     /etc/systemd/system/linux-agent-web.service.d/10-provider-egress.conf
# Then edit IPAddressAllow lines for your Provider CIDRs and:
#   sudo systemctl daemon-reload && sudo systemctl restart linux-agent-web
#
# Default: deny all, allow loopback only. AI Provider calls will fail until
# the operator adds explicit egress CIDRs for the configured api_url hosts.

[Service]
IPAddressDeny=any
IPAddressAllow=localhost
# IPAddressAllow=203.0.113.0/24
